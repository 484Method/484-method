# Copie este arquivo para .env e preencha com os valores reais.
# O .env está no .gitignore e nunca deve ser commitado.

# Portal Azure > seu recurso Speech > "Chaves e Ponto de Extremidade"
AZURE_SPEECH_KEY=cole_a_chave_1_aqui
AZURE_SPEECH_REGION=brazilsouth

# Supabase > Project Settings > API. A anon key é pública (RLS protege os
# dados); pode ir no cliente. Vazias = app roda em modo local.
SUPABASE_URL=
SUPABASE_ANON_KEY=
